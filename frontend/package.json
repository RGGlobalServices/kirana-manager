{
  "name": "ai-studio-applet",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npx dotenv-cli -e ../.env.local -- cross-env NODE_OPTIONS=--max-old-space-size=2048 next dev",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=2048 next build",
    "start": "cross-env NODE_OPTIONS=--max-old-space-size=2048 next start",
    "lint": "eslint .",
    "clean": "next clean",
    "mobile:init": "npx cap init",
    "mobile:add": "npx cap add android",
    "mobile:sync": "npx cap sync",
    "mobile:build": "npm run build && npx cap sync",
    "mobile:open": "npx cap open android",
    "desktop:start": "electron ."
  },
  "dependencies": {
    "@capacitor/android": "^8.3.3",
    "@capacitor/cli": "^8.3.3",
    "@capacitor/core": "^8.3.3",
    "@capacitor/ios": "^8.3.3",
    "@google/genai": "^1.17.0",
    "@opentelemetry/api": "^1.6.0",
    "@swc/core": "^1.15.30",
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "autoprefixer": "^10.4.21",
    "buffer": "^6.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "html2canvas-pro": "^2.0.2",
    "html5-qrcode": "^2.3.8",
    "jsbarcode": "^3.12.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.553.0",
    "next": "^15.5.15",
    "next-intl": "^4.9.0",
    "openai": "^6.34.0",
    "pdf-parse": "^1.1.1",
    "pdf2json": "^4.0.3",
    "postcss": "^8.5.6",
    "qrcode": "^1.5.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "recharts": "^3.8.1",
