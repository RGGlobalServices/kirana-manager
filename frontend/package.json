    "@tailwindcss/postcss": "4.1.11",
    "@tailwindcss/typography": "^0.5.19",
    "@types/jsbarcode": "^3.11.4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^8.0.0",
    "electron": "^42.0.1",
    "electron-is-dev": "^3.0.1",
    "eslint": "9.39.1",
    "eslint-config-next": "^15.5.15",
    "tailwindcss": "4.1.11",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3"
